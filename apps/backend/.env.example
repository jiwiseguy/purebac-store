# ── Core ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/medusa-purebac
REDIS_URL=redis://host:6379
JWT_SECRET=change-me
COOKIE_SECRET=change-me
AUTH_MFA_ENCRYPTION_KEY=change-me

# ── CORS (set to your deployed storefront + admin origins) ──────────
STORE_CORS=https://purebac.com,https://www.purebac.com
ADMIN_CORS=https://<backend-host>
AUTH_CORS=https://purebac.com,https://www.purebac.com,https://<backend-host>

# ── Email (Resend) ──────────────────────────────────────────────────
# Until a domain is verified in Resend, send from onboarding@resend.dev and
# only to the Resend account's own email (works for owner order notifications).
FROM_EMAIL=PureBac <onboarding@resend.dev>
RESEND_API_KEY=
# Store owner gets a full order + shipping email here on every order:
ORDER_NOTIFICATION_EMAIL=purebackwater1@gmail.com

# ── File storage (Cloudflare R2 / S3) ───────────────────────────────
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ── Shipping labels (Shippo) — "Create Label" button on the order page ─
# Use a TEST token (shippo_test_...) first, then the live token.
SHIPPO_API_KEY=
SHIP_FROM_NAME=PureBac
SHIP_FROM_COMPANY=PureBac
SHIP_FROM_STREET1=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=
SHIP_FROM_EMAIL=purebackwater1@gmail.com
# Optional parcel defaults (inches / ounces) and forced service level:
# PARCEL_LENGTH=6
# PARCEL_WIDTH=4
# PARCEL_HEIGHT=2
# PARCEL_WEIGHT_OZ=8
# SHIPPO_SERVICELEVEL=usps_priority
