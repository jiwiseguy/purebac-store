# ── Core ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/medusa-purebac
REDIS_URL=redis://host:6379
JWT_SECRET=change-me
COOKIE_SECRET=change-me
AUTH_MFA_ENCRYPTION_KEY=change-me

# ── CORS (set to your deployed storefront + admin origins) ──────────
STORE_CORS=https://purebac.com,https://www.purebac.com
ADMIN_CORS=https://<backend-host>
AUTH_CORS=https://purebac.com,https://www.purebac.com,https://<backend-host>

# ── Email (Resend) ──────────────────────────────────────────────────
FROM_EMAIL=PureBac <orders@purebac.com>
RESEND_API_KEY=

# ── File storage (Cloudflare R2 / S3) ───────────────────────────────
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
